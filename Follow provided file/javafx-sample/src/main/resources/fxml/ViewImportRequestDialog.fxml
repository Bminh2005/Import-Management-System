<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.importassignment.controllers.ViewImportRequestDialogController"
      spacing="20" styleClass="dialog-content" prefWidth="900" prefHeight="700">

    <padding>
        <Insets top="24" right="24" bottom="24" left="24"/>
    </padding>

    <!-- Header -->
    <VBox spacing="8">
        <Label fx:id="titleLabel" text="Chi tiết Yêu cầu Nhập hàng" styleClass="dialog-title"/>
        <Label fx:id="subtitleLabel" text="Thông tin chi tiết về yêu cầu và các đơn hàng liên quan" styleClass="page-subtitle"/>
    </VBox>

    <Separator/>

    <!-- Request Info Section -->
    <VBox spacing="16">
        <Label text="Thông tin Yêu cầu" styleClass="section-title"/>

        <GridPane hgap="24" vgap="12">
            <columnConstraints>
                <ColumnConstraints percentWidth="25"/>
                <ColumnConstraints percentWidth="25"/>
                <ColumnConstraints percentWidth="25"/>
                <ColumnConstraints percentWidth="25"/>
            </columnConstraints>

            <!-- Row 1 -->
            <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="0">
                <Label text="Mã yêu cầu" styleClass="info-label"/>
                <Label fx:id="requestCodeLabel" text="-" styleClass="info-value"/>
            </VBox>

            <VBox spacing="4" GridPane.columnIndex="1" GridPane.rowIndex="0">
                <Label text="Ngày tạo" styleClass="info-label"/>
                <Label fx:id="createdDateLabel" text="-" styleClass="info-value"/>
            </VBox>

            <VBox spacing="4" GridPane.columnIndex="2" GridPane.rowIndex="0">
                <Label text="Trạng thái" styleClass="info-label"/>
                <HBox>
                    <Label fx:id="statusLabel" text="-" styleClass="status-badge"/>
                </HBox>
            </VBox>

            <VBox spacing="4" GridPane.columnIndex="3" GridPane.rowIndex="0">
                <Label text="Số mặt hàng" styleClass="info-label"/>
                <Label fx:id="itemCountLabel" text="-" styleClass="info-value"/>
            </VBox>
        </GridPane>
    </VBox>

    <Separator/>

    <!-- Request Items Section -->
    <VBox spacing="12" VBox.vgrow="SOMETIMES">
        <Label text="Danh sách Mặt hàng" styleClass="section-title"/>

        <TableView fx:id="requestItemsTable" VBox.vgrow="ALWAYS" styleClass="data-table">
            <columns>
                <TableColumn fx:id="itemCodeColumn" text="Mã hàng" prefWidth="100"/>
                <TableColumn fx:id="itemNameColumn" text="Tên mặt hàng" prefWidth="200"/>
                <TableColumn fx:id="itemQuantityColumn" text="Số lượng" prefWidth="100"/>
                <TableColumn fx:id="itemUnitColumn" text="Đơn vị" prefWidth="80"/>
                <TableColumn fx:id="itemDeliveryDateColumn" text="Ngày nhận mong muốn" prefWidth="150"/>
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
            </columnResizePolicy>
        </TableView>
    </VBox>

    <Separator/>

    <!-- Related Orders Section -->
    <VBox spacing="12" VBox.vgrow="SOMETIMES">
        <HBox alignment="CENTER_LEFT" spacing="12">
            <Label text="Đơn hàng liên quan" styleClass="section-title"/>
            <Label fx:id="orderCountLabel" text="(0 đơn)" styleClass="info-label"/>
        </HBox>

        <Label fx:id="noOrdersLabel" text="Chưa có đơn hàng nào được tạo từ yêu cầu này"
               styleClass="empty-state-text" managed="false" visible="false">
            <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
        </Label>

        <TableView fx:id="ordersTable" VBox.vgrow="ALWAYS" styleClass="data-table">
            <columns>
                <TableColumn fx:id="orderCodeColumn" text="Mã đơn hàng" prefWidth="120"/>
                <TableColumn fx:id="orderDateColumn" text="Ngày tạo" prefWidth="100"/>
                <TableColumn fx:id="orderSiteColumn" text="Site được phân" prefWidth="150"/>
                <TableColumn fx:id="orderItemsColumn" text="Số mặt hàng" prefWidth="100"/>
                <TableColumn fx:id="orderStatusColumn" text="Trạng thái" prefWidth="120"/>
                <TableColumn fx:id="orderActionsColumn" text="Thao tác" prefWidth="100"/>
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
            </columnResizePolicy>
        </TableView>
    </VBox>

    <!-- Footer Actions -->
    <HBox spacing="12" alignment="CENTER_RIGHT">
        <padding>
            <Insets top="12"/>
        </padding>

        <Button text="Đóng" styleClass="btn-secondary" onAction="#onClose">
            <padding><Insets top="12" right="24" bottom="12" left="24"/></padding>
        </Button>
    </HBox>

</VBox>
