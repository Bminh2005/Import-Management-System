<?xml version="1.0" encoding="UTF-8"?>
<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<BorderPane fx:controller="com.app.Ioms.ui.orders.ConfirmOrdersView" xmlns:fx="http://javafx.com/fxml">
    <top>
        <HBox spacing="10">
            <children>
                <Label text="Xác nhận phân bổ và gửi đơn" style="-fx-font-size: 16; -fx-font-weight: bold;"/>
                <Label text="Đơn:"/>
                <Label fx:id="lblOrderId"/>
                <Pane HBox.hgrow="ALWAYS"/>
                <Button fx:id="btnSend" text="Gửi đơn ✔"/>
            </children>
            <padding>
                <Insets top="8" bottom="8" left="4" right="4"/>
            </padding>
        </HBox>
    </top>
    <center>
        <TextArea fx:id="txtSummary" editable="false" prefRowCount="16"/>
    </center>
</BorderPane>
