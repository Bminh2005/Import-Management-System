<?xml version="1.0" encoding="UTF-8"?>
<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<BorderPane fx:controller="com.app.Ioms.ui.orders.CanceledOrdersView" xmlns:fx="http://javafx.com/fxml">
    <top>
        <HBox spacing="12">
            <children>
                <Label text="Đơn hủy theo site" style="-fx-font-size: 16; -fx-font-weight: bold;"/>
                <Label text="Site:"/>
                <ComboBox fx:id="cboSite" prefWidth="220"/>
                <Pane HBox.hgrow="ALWAYS"/>
                <Button fx:id="btnReprocess" text="Xử lý lại"/>
            </children>
            <padding>
                <Insets top="8" bottom="8" left="4" right="4"/>
            </padding>
        </HBox>
    </top>
    <center>
        <TableView fx:id="tblCanceled">
            <columns>
                <TableColumn fx:id="colId" text="ID" prefWidth="260"/>
                <TableColumn fx:id="colCustomer" text="Khách hàng" prefWidth="220"/>
                <TableColumn fx:id="colSite" text="Site hủy" prefWidth="120"/>
            </columns>
        </TableView>
    </center>
</BorderPane>
