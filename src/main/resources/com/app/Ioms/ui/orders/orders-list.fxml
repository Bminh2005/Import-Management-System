<?xml version="1.0" encoding="UTF-8"?>
<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<BorderPane fx:controller="com.app.Ioms.ui.orders.OrdersListView" xmlns:fx="http://javafx.com/fxml">
    <top>
        <HBox spacing="10">
            <children>
                <Label text="Danh sách đơn hàng" style="-fx-font-size: 16; -fx-font-weight: bold;"/>
                <Pane HBox.hgrow="ALWAYS"/>
                <Button text="Làm mới" onAction="#refresh"/>
                <Button fx:id="btnCanceled" text="Xem đơn hủy theo site"/>
                <Button fx:id="btnOpen" text="Mở chi tiết"/>
            </children>
            <padding>
                <Insets top="8" bottom="8" left="4" right="4"/>
            </padding>
        </HBox>
    </top>
    <center>
        <TableView fx:id="tblOrders">
            <columns>
                <TableColumn fx:id="colId" text="ID" prefWidth="260"/>
                <TableColumn fx:id="colCustomer" text="Khách hàng" prefWidth="200"/>
                <TableColumn fx:id="colStatus" text="Trạng thái" prefWidth="160"/>
            </columns>
        </TableView>
    </center>
</BorderPane>
