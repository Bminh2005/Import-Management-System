<?xml version="1.0" encoding="UTF-8"?>
<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>

<BorderPane fx:controller="com.app.Ioms.ui.main.MainShell" xmlns:fx="http://javafx.com/fxml">
    <top>
        <HBox spacing="12" styleClass="app-header">
            <children>
                <Label text="IOMS - International Order Management" styleClass="app-title"/>
            </children>
            <padding>
                <Insets top="14" bottom="14" left="18" right="18"/>
            </padding>
        </HBox>
    </top>
    <left>
        <VBox spacing="10" styleClass="sidebar">
            <children>
                <Button fx:id="btnOrders" text="Đơn hàng" onAction="#onOrders" maxWidth="Infinity"/>
                <Button fx:id="btnCanceled" text="Đơn hủy theo site" onAction="#onCanceled" maxWidth="Infinity"/>
                <Button fx:id="btnAllocation" text="Phân bổ" onAction="#onAllocation" maxWidth="Infinity"/>
                <Button fx:id="btnConfirm" text="Xác nhận" onAction="#onConfirm" maxWidth="Infinity"/>
            </children>
            <padding>
                <Insets top="16" bottom="16" left="12" right="12"/>
            </padding>
        </VBox>
    </left>
    <center>
        <StackPane fx:id="contentOutlet" styleClass="content-outlet"/>
    </center>
</BorderPane>
