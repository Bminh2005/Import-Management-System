<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import java.net.URL?>

<fx:root type="javafx.scene.control.ScrollPane"
         xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
         fitToWidth="true" styleClass="screen-scroll">
    <stylesheets>
        <URL value="@../../../../../common/ui/components/common.css"/>
        <URL value="@RequestDetailPage.css"/>
    </stylesheets>

    <VBox styleClass="main-content" spacing="24">
        <padding>
            <Insets top="32" right="32" bottom="32" left="32"/>
        </padding>

        <!-- Tiêu đề trang -->
        <VBox spacing="4">
            <Label text="Chi tiết Yêu cầu Nhập hàng" styleClass="page-title"/>
            <Label text="Thông tin chi tiết về yêu cầu và các đơn hàng liên quan"
                   styleClass="page-subtitle"/>
        </VBox>

        <!-- Thẻ thông tin yêu cầu -->
        <VBox styleClass="card" spacing="16">
            <padding>
                <Insets top="20" right="24" bottom="20" left="24"/>
            </padding>
            <Label text="Thông tin Yêu cầu" styleClass="section-title"/>

            <GridPane hgap="24" vgap="12">
                <columnConstraints>
                    <ColumnConstraints percentWidth="25"/>
                    <ColumnConstraints percentWidth="25"/>
                    <ColumnConstraints percentWidth="25"/>
                    <ColumnConstraints percentWidth="25"/>
                </columnConstraints>

                <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="0">
                    <Label text="MÃ YÊU CẦU" styleClass="info-label"/>
                    <Label fx:id="codeLabel" text="-" styleClass="info-value"/>
                </VBox>

                <VBox spacing="4" GridPane.columnIndex="1" GridPane.rowIndex="0">
                    <Label text="NGÀY TẠO" styleClass="info-label"/>
                    <Label fx:id="createdDateLabel" text="-" styleClass="info-value"/>
                </VBox>

                <VBox spacing="4" GridPane.columnIndex="2" GridPane.rowIndex="0">
                    <Label text="TRẠNG THÁI" styleClass="info-label"/>
                    <HBox>
                        <Label fx:id="statusLabel" text="-"/>
                    </HBox>
                </VBox>

                <VBox spacing="4" GridPane.columnIndex="3" GridPane.rowIndex="0">
                    <Label text="SỐ MẶT HÀNG" styleClass="info-label"/>
                    <Label fx:id="itemCountLabel" text="-" styleClass="info-value"/>
                </VBox>

                <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="1">
                    <Label text="NGƯỜI TẠO" styleClass="info-label"/>
                    <Label fx:id="createdByLabel" text="-" styleClass="info-value"/>
                </VBox>

                <VBox spacing="4" GridPane.columnIndex="1" GridPane.rowIndex="1"
                      GridPane.columnSpan="3">
                    <Label text="ĐƠN VỊ XỬ LÝ" styleClass="info-label"/>
                    <Label fx:id="assignedToLabel" text="-" styleClass="info-value"/>
                </VBox>
            </GridPane>
        </VBox>

        <!-- Danh sách mặt hàng (chỉ đọc) -->
        <VBox styleClass="card" spacing="16">
            <padding>
                <Insets top="20" right="24" bottom="20" left="24"/>
            </padding>
            <Label text="Danh sách Mặt hàng" styleClass="section-title"/>
            <TableView fx:id="itemsTable" styleClass="data-table" prefHeight="240">
                <columns>
                    <TableColumn fx:id="codeColumn" text="Mã hàng" prefWidth="100"/>
                    <TableColumn fx:id="nameColumn" text="Tên mặt hàng" prefWidth="220"/>
                    <TableColumn fx:id="quantityColumn" text="Số lượng" prefWidth="90"/>
                    <TableColumn fx:id="unitColumn" text="Đơn vị" prefWidth="80"/>
                    <TableColumn fx:id="deliveryDateColumn" text="Ngày nhận mong muốn"
                                 prefWidth="160"/>
                    <TableColumn fx:id="statusColumn" text="Trạng thái" prefWidth="110"/>
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                </columnResizePolicy>
            </TableView>
        </VBox>

        <!-- Mặt hàng bị từ chối / hủy -->
        <VBox fx:id="rejectedCard" styleClass="card-danger" spacing="16">
            <padding>
                <Insets top="20" right="24" bottom="20" left="24"/>
            </padding>
            <HBox spacing="12" alignment="CENTER_LEFT">
                <Label text="Mặt hàng Bị từ chối / Hủy"
                       styleClass="section-title-danger"/>
                <Label fx:id="rejectedCountLabel" text="(0 mặt hàng)"
                       styleClass="info-label"/>
            </HBox>
            <VBox fx:id="rejectedList" spacing="12"/>
            <Label fx:id="rejectedEmptyLabel"
                   text="Không có mặt hàng nào bị từ chối hoặc hủy"
                   styleClass="empty-state" managed="false" visible="false"/>
        </VBox>

        <!-- Đơn hàng liên quan -->
        <VBox styleClass="card" spacing="16">
            <padding>
                <Insets top="20" right="24" bottom="20" left="24"/>
            </padding>
            <HBox spacing="12" alignment="CENTER_LEFT">
                <Label text="Đơn hàng liên quan" styleClass="section-title"/>
                <Label fx:id="orderCountLabel" text="(0 đơn)" styleClass="info-label"/>
            </HBox>

            <Label fx:id="orderEmptyLabel"
                   text="Chưa có đơn hàng nào được tạo từ yêu cầu này"
                   styleClass="empty-state" managed="false" visible="false"/>

            <TableView fx:id="ordersTable" styleClass="data-table" prefHeight="220">
                <columns>
                    <TableColumn fx:id="orderCodeColumn" text="Mã đơn hàng"
                                 prefWidth="120"/>
                    <TableColumn fx:id="orderDateColumn" text="Ngày tạo"
                                 prefWidth="100"/>
                    <TableColumn fx:id="orderSiteColumn" text="Site được phân"
                                 prefWidth="170"/>
                    <TableColumn fx:id="orderItemCountColumn" text="Số mặt hàng"
                                 prefWidth="100"/>
                    <TableColumn fx:id="orderStatusColumn" text="Trạng thái"
                                 prefWidth="120"/>
                    <TableColumn fx:id="orderActionsColumn" text="Thao tác"
                                 prefWidth="120"/>
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                </columnResizePolicy>
            </TableView>
        </VBox>

        <!-- Nút thao tác cuối trang -->
        <HBox spacing="12" alignment="CENTER_RIGHT">
            <padding>
                <Insets top="8"/>
            </padding>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Đóng" styleClass="btn-secondary" onAction="#onClose"/>
        </HBox>
    </VBox>
</fx:root>
