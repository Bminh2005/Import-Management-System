<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import java.net.URL?>

<fx:root type="javafx.scene.layout.VBox"
         xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
         styleClass="enter-dialog" spacing="0" prefWidth="500">
    <stylesheets>
        <URL value="@../../../../../common/ui/components/common.css"/>
        <URL value="@EnterItemInfoDialogPage.css"/>
    </stylesheets>

    <!-- Header -->
    <HBox styleClass="dialog-header" alignment="CENTER_LEFT">
        <padding>
            <Insets top="18" right="22" bottom="14" left="22"/>
        </padding>
        <VBox spacing="2" HBox.hgrow="ALWAYS">
            <Label text="Thêm vào yêu cầu" styleClass="dialog-title"/>
            <Label fx:id="productNameLabel" text="-" styleClass="dialog-subtitle"/>
        </VBox>
    </HBox>

    <Region styleClass="dialog-divider"/>

    <!-- Body -->
    <VBox styleClass="dialog-body" spacing="18">
        <padding>
            <Insets top="20" right="22" bottom="20" left="22"/>
        </padding>

        <!-- Info chip mã + đơn vị -->
        <HBox spacing="20" alignment="CENTER_LEFT">
            <VBox spacing="4">
                <Label text="MÃ HÀNG" styleClass="info-label"/>
                <Label fx:id="codeLabel" text="-" styleClass="info-value"/>
            </VBox>
            <VBox spacing="4">
                <Label text="ĐƠN VỊ" styleClass="info-label"/>
                <Label fx:id="unitLabel" text="-" styleClass="info-value"/>
            </VBox>
        </HBox>

        <GridPane hgap="16" vgap="6">
            <columnConstraints>
                <ColumnConstraints percentWidth="50"/>
                <ColumnConstraints percentWidth="50"/>
            </columnConstraints>

            <VBox spacing="6" GridPane.columnIndex="0" GridPane.rowIndex="0">
                <HBox spacing="2">
                    <Label text="Số lượng" styleClass="form-label"/>
                    <Label text="*" styleClass="form-required"/>
                </HBox>
                <Spinner fx:id="quantitySpinner" editable="true" styleClass="form-field"/>
            </VBox>

            <VBox spacing="6" GridPane.columnIndex="1" GridPane.rowIndex="0">
                <HBox spacing="2">
                    <Label text="Ngày nhận mong muốn" styleClass="form-label"/>
                    <Label text="*" styleClass="form-required"/>
                </HBox>
                <DatePicker fx:id="deliveryDatePicker" maxWidth="Infinity"
                            styleClass="form-field"/>
            </VBox>
        </GridPane>

        <Label fx:id="errorLabel" styleClass="form-required" wrapText="true"
               managed="false" visible="false"/>
    </VBox>

    <Region styleClass="dialog-divider"/>

    <!-- Footer -->
    <HBox styleClass="dialog-footer" alignment="CENTER_RIGHT" spacing="10">
        <padding>
            <Insets top="14" right="22" bottom="16" left="22"/>
        </padding>
        <Button text="Hủy" styleClass="btn-secondary" onAction="#onCancel"/>
        <Button text="Thêm vào yêu cầu" styleClass="btn-primary" onAction="#onConfirm"/>
    </HBox>
</fx:root>
