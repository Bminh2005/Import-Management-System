<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<fx:root type="javafx.scene.layout.VBox"
         xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
         stylesheets="@requestListStyle.css" styleClass="main-content" spacing="20">

    <padding>
        <Insets top="24" right="32" bottom="24" left="32"/>
    </padding>

    <HBox alignment="CENTER_LEFT">
        <VBox spacing="4" HBox.hgrow="ALWAYS">
            <Label text="Yêu cầu Nhập hàng" styleClass="main-title"/>
            <Label text="Quản lý yêu cầu nhập hàng của bạn" styleClass="subtitle"/>
        </VBox>
        <Button text="+ Tạo Yêu cầu Mới" styleClass="btn-primary" fx:id="btnCreateRequest"/>
    </HBox>

    <VBox styleClass="card" spacing="16">
        <padding>
            <Insets top="16" right="16" bottom="16" left="16"/>
        </padding>

        <TextField fx:id="txtSearch" promptText="Tìm kiếm theo mã yêu cầu..." styleClass="search-field"/>

        <HBox fx:id="filterBar" spacing="10" alignment="CENTER_LEFT"/>
    </VBox>

    <VBox styleClass="card" VBox.vgrow="ALWAYS" spacing="16">
        <padding>
            <Insets top="0" right="0" bottom="16" left="0"/>
        </padding>

        <TableView fx:id="tableRequests" VBox.vgrow="ALWAYS" styleClass="custom-table">
            <columns>
                <TableColumn fx:id="colId" text="MÃ YÊU CẦU" prefWidth="180"/>
                <TableColumn fx:id="colDate" text="NGÀY TẠO" prefWidth="150"/>
                <TableColumn fx:id="colQuantity" text="SỐ MẶT HÀNG" prefWidth="120"/>
                <TableColumn fx:id="colStatus" text="TRẠNG THÁI" prefWidth="150"/>
                <TableColumn fx:id="colActions" text="THAO TÁC" prefWidth="120"/>
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
            </columnResizePolicy>
        </TableView>

        <HBox alignment="CENTER_LEFT" styleClass="pagination-container">
            <padding>
                <Insets left="16" right="16"/>
            </padding>

            <Label fx:id="paginationInfoLabel" text="Hiển thị 0 yêu cầu" styleClass="pagination-info"/>

            <Region HBox.hgrow="ALWAYS"/>

            <HBox spacing="5" alignment="CENTER_RIGHT">
                <Button fx:id="btnPrev" text="Trước" styleClass="btn-page" onAction="#onPrevPage"/>
                <HBox fx:id="pageButtonsBox" spacing="5" alignment="CENTER_RIGHT"/>
                <Button fx:id="btnNext" text="Sau" styleClass="btn-page" onAction="#onNextPage"/>
            </HBox>
        </HBox>
    </VBox>
</fx:root>
