<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import java.net.URL?>

<fx:root type="javafx.scene.layout.VBox"
         xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
         styleClass="order-dialog" spacing="0" prefWidth="900">
    <stylesheets>
        <URL value="@../../../../../common/ui/components/common.css"/>
        <URL value="@OrderDetailDialogPage.css"/>
    </stylesheets>

    <!-- Header -->
    <HBox styleClass="dialog-header" alignment="CENTER_LEFT">
        <padding>
            <Insets top="20" right="24" bottom="16" left="24"/>
        </padding>
        <VBox spacing="4" HBox.hgrow="ALWAYS">
            <Label text="Chi tiết Đơn hàng" styleClass="dialog-title"/>
            <Label text="Thông tin chi tiết về đơn hàng và mặt hàng"
                   styleClass="dialog-subtitle"/>
        </VBox>
    </HBox>

    <Region styleClass="dialog-divider"/>

    <!-- Body -->
    <VBox styleClass="dialog-body" spacing="24">
        <padding>
            <Insets top="20" right="24" bottom="20" left="24"/>
        </padding>

        <!-- Thông tin đơn hàng -->
        <VBox spacing="14">
            <Label text="Thông tin Đơn hàng" styleClass="section-title"/>

            <GridPane hgap="24" vgap="16">
                <columnConstraints>
                    <ColumnConstraints percentWidth="33.33"/>
                    <ColumnConstraints percentWidth="33.33"/>
                    <ColumnConstraints percentWidth="33.33"/>
                </columnConstraints>

                <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="0">
                    <Label text="MÃ ĐƠN HÀNG" styleClass="info-label"/>
                    <Label fx:id="codeLabel" text="-" styleClass="info-value"/>
                </VBox>

                <VBox spacing="4" GridPane.columnIndex="1" GridPane.rowIndex="0">
                    <Label text="NGÀY TẠO" styleClass="info-label"/>
                    <Label fx:id="dateLabel" text="-" styleClass="info-value"/>
                </VBox>

                <VBox spacing="4" GridPane.columnIndex="2" GridPane.rowIndex="0">
                    <Label text="TRẠNG THÁI" styleClass="info-label"/>
                    <HBox>
                        <Label fx:id="statusLabel" text="-"/>
                    </HBox>
                </VBox>

                <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="1">
                    <Label text="MÃ YÊU CẦU GỐC" styleClass="info-label"/>
                    <Label fx:id="requestCodeLabel" text="-" styleClass="info-value"/>
                </VBox>

                <VBox spacing="4" GridPane.columnIndex="1" GridPane.rowIndex="1"
                      GridPane.columnSpan="2">
                    <Label text="SITE ĐƯỢC PHÂN" styleClass="info-label"/>
                    <Label fx:id="siteLabel" text="-" styleClass="info-value"/>
                </VBox>
            </GridPane>
        </VBox>

        <Region styleClass="dialog-divider"/>

        <!-- Danh sách mặt hàng -->
        <VBox spacing="14">
            <Label text="Danh sách Mặt hàng" styleClass="section-title"/>

            <TableView fx:id="itemsTable" styleClass="data-table" prefHeight="240">
                <columns>
                    <TableColumn fx:id="codeColumn" text="MÃ HÀNG" prefWidth="120"/>
                    <TableColumn fx:id="nameColumn" text="TÊN MẶT HÀNG" prefWidth="280"/>
                    <TableColumn fx:id="quantityColumn" text="SỐ LƯỢNG" prefWidth="140"/>
                    <TableColumn fx:id="unitColumn" text="ĐƠN VỊ" prefWidth="120"/>
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                </columnResizePolicy>
            </TableView>
        </VBox>
    </VBox>

    <Region styleClass="dialog-divider"/>

    <!-- Footer -->
    <HBox styleClass="dialog-footer" alignment="CENTER_RIGHT" spacing="12">
        <padding>
            <Insets top="16" right="24" bottom="20" left="24"/>
        </padding>
        <Button text="Đóng" styleClass="btn-secondary" onAction="#onClose"/>
    </HBox>
</fx:root>
