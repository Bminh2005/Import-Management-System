<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import java.net.URL?>

<fx:root type="javafx.scene.layout.VBox"
         xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
         styleClass="cancel-dialog" spacing="0" prefWidth="560">
    <stylesheets>
        <URL value="@../../../../common/ui/components/common.css"/>
        <URL value="@CancelOrderDialogPage.css"/>
    </stylesheets>

    <!-- Header đỏ -->
    <HBox styleClass="cancel-header" alignment="CENTER_LEFT" spacing="16">
        <padding>
            <Insets top="18" right="20" bottom="18" left="20"/>
        </padding>
        <StackPane styleClass="cancel-icon-box">
            <Label text="✕" styleClass="cancel-icon-x"/>
        </StackPane>
        <VBox spacing="2">
            <Label text="Hủy đơn hàng" styleClass="cancel-title"/>
            <Label fx:id="subtitleLabel" text="Xác nhận hủy đơn hàng"
                   styleClass="cancel-subtitle"/>
        </VBox>
    </HBox>

    <!-- Body -->
    <VBox styleClass="cancel-body" spacing="18">
        <padding>
            <Insets top="20" right="22" bottom="20" left="22"/>
        </padding>

        <!-- Cảnh báo -->
        <HBox styleClass="warning-box" spacing="0">
            <padding>
                <Insets top="14" right="16" bottom="14" left="16"/>
            </padding>
            <Label fx:id="warningLabel" wrapText="true" styleClass="warning-text"
                   text="Cảnh báo: Hành động này sẽ hủy đơn hàng. Đơn hàng sẽ không thể khôi phục sau khi hủy."/>
        </HBox>

        <!-- Info card: chỉ SITE (bỏ giá trị) -->
        <HBox styleClass="info-card" spacing="32">
            <padding>
                <Insets top="14" right="18" bottom="14" left="18"/>
            </padding>
            <VBox spacing="4">
                <Label text="SITE" styleClass="info-label"/>
                <Label fx:id="siteLabel" text="-" styleClass="info-value"/>
            </VBox>
        </HBox>

        <!-- Lý do hủy -->
        <VBox spacing="6">
            <HBox spacing="2">
                <Label text="Lý do hủy đơn hàng" styleClass="form-label"/>
                <Label text="*" styleClass="form-required"/>
            </HBox>
            <TextArea fx:id="reasonField" promptText="Nhập lý do hủy đơn hàng..."
                      prefRowCount="4" wrapText="true" styleClass="reason-field"/>
            <Label fx:id="errorLabel" styleClass="form-required" wrapText="true"
                   managed="false" visible="false"/>
        </VBox>
    </VBox>

    <Region styleClass="dialog-divider"/>

    <!-- Footer -->
    <HBox styleClass="cancel-footer" alignment="CENTER_RIGHT" spacing="10">
        <padding>
            <Insets top="14" right="20" bottom="18" left="20"/>
        </padding>
        <Button text="Quay lại" styleClass="btn-secondary" onAction="#onBack"/>
        <Button text="Xác nhận hủy" styleClass="btn-danger" onAction="#onConfirm"/>
    </HBox>
</fx:root>
