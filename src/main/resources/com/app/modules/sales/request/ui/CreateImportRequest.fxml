<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.shape.SVGPath?>

<fx:root type="VBox" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      stylesheets="@CreateRequestStyle.css" styleClass="main-content" spacing="20">

    <padding>
        <Insets top="24" right="32" bottom="24" left="32"/>
    </padding>

    <HBox spacing="15" alignment="CENTER_LEFT">
        <Button styleClass="btn-back">
            <graphic>
                <SVGPath content="M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.41-1.41L7.83 13H20v-2z" fill="#475569"/>
            </graphic>
        </Button>
        <VBox spacing="4">
            <Label text="Tạo Yêu cầu Nhập hàng" styleClass="main-title"/>
            <Label text="Thêm các mặt hàng cần nhập vào hệ thống" styleClass="subtitle"/>
        </VBox>
    </HBox>

    <HBox styleClass="info-box" alignment="CENTER_LEFT">
        <Label text="Vui lòng chọn các mặt hàng cần nhập và chỉ định số lượng cùng ngày nhận mong muốn. Mã yêu cầu sẽ được tạo tự động sau khi lưu."
               wrapText="true" styleClass="info-text"/>
    </HBox>

    <VBox styleClass="card" VBox.vgrow="ALWAYS" spacing="20">
        <padding>
            <Insets top="20" right="20" bottom="20" left="20"/>
        </padding>

        <HBox alignment="CENTER_LEFT">
            <Label text="Danh sách mặt hàng" styleClass="section-title"/>

            <Region HBox.hgrow="ALWAYS"/>

            <Button fx:id="addMerchandiseButton" text="+ Thêm mặt hàng" styleClass="btn-secondary"/>
        </HBox>

        <StackPane VBox.vgrow="ALWAYS">
            <TableView fx:id="tableItems" styleClass="custom-table">
                <columns>
                    <TableColumn fx:id="colMaHang" text="MÃ HÀNG" minWidth="70" prefWidth="70" maxWidth="70"/>
                    <TableColumn fx:id="colTenHang" text="TÊN MẶT HÀNG" prefWidth="250"/>

                    <TableColumn fx:id="colSoLuong" text="SỐ LƯỢNG" minWidth="90" prefWidth="90" maxWidth="90"/>

                    <TableColumn fx:id="colDonVi" text="ĐƠN VỊ" minWidth="110" prefWidth="110" maxWidth="110"/>
                    <TableColumn fx:id="colGiaThamKhao"  text="GIÁ THAM KHẢO" minWidth="160" prefWidth="160" maxWidth="160"/>

                    <TableColumn fx:id="colNgayNhan" text="NGÀY NHẬN (MONG MUỐN)" minWidth="200" prefWidth="200" maxWidth="200"/>

                    <TableColumn fx:id="colThaoTac" text="" minWidth="40" prefWidth="40" maxWidth="40"/>
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                </columnResizePolicy>
                <placeholder>
                    <VBox alignment="CENTER" spacing="10">
                        <Label text="Chưa có mặt hàng nào. Click &quot;Thêm mặt hàng&quot; để bắt đầu."
                               styleClass="placeholder-text"/>
                    </VBox>
                </placeholder>
            </TableView>
        </StackPane>
    </VBox>

    <HBox alignment="CENTER_LEFT">
        <Region HBox.hgrow="ALWAYS"/>

        <HBox spacing="12">
            <Button fx:id="cancelButton" text="Hủy bỏ" styleClass="btn-outline"/>
            <Button fx:id="createButton" text="Tạo Yêu cầu" styleClass="btn-primary">
                <graphic>
                    <SVGPath content="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z" fill="white"/>
                </graphic>
            </Button>
        </HBox>
    </HBox>

</fx:root>