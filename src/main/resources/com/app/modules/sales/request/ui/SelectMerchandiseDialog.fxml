<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.shape.SVGPath?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.app.modules.sales.request.createrequest.ui.SelectMerchandiseController"
      stylesheets="@CreateRequestStyle.css" styleClass="popup-container"
      prefWidth="560" prefHeight="540" spacing="0"> <HBox alignment="CENTER_LEFT" styleClass="popup-header">
    <padding>
        <Insets top="20" right="24" bottom="12" left="24"/>
    </padding>
    <Label text="Chọn mặt hàng" styleClass="popup-title"/>
    <Region HBox.hgrow="ALWAYS"/>
    <Button fx:id="btnXClose" styleClass="btn-icon-close">
        <graphic>
            <SVGPath content="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z" fill="#94a3b8"/>
        </graphic>
    </Button>
</HBox>

    <HBox alignment="CENTER_LEFT" styleClass="search-bar-container">
        <padding>
            <Insets top="4" right="24" bottom="12" left="24"/>
        </padding>
        <HBox alignment="CENTER_LEFT" styleClass="search-box" HBox.hgrow="ALWAYS" spacing="10">
            <padding>
                <Insets top="8" right="12" bottom="8" left="12"/>
            </padding>
            <SVGPath content="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z" fill="#94a3b8"/>
            <TextField fx:id="txtSearch" promptText="Tìm kiếm theo mã hoặc tên mặt hàng..." HBox.hgrow="ALWAYS" styleClass="search-input"/>
        </HBox>
    </HBox>

    <Separator styleClass="popup-separator"/>

    <StackPane VBox.vgrow="ALWAYS">
        <padding>
            <Insets top="16" right="24" bottom="16" left="24"/>
        </padding>
        <ListView fx:id="lvMerchandise" styleClass="popup-list-view"/>
    </StackPane>

    <Separator styleClass="popup-separator"/>

    <HBox alignment="CENTER_RIGHT" styleClass="popup-footer" spacing="12">
        <padding>
            <Insets top="16" right="24" bottom="16" left="24"/>
        </padding>
        <Button fx:id="btnClose" text="Hủy bỏ" styleClass="btn-dialog-close"/>
        <Button fx:id="btnSubmit" text="Thêm mặt hàng" styleClass="btn-primary"/>
    </HBox>

</VBox>