<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import com.app.common.ui.components.WarehouseTopBarUI?>
<?import com.app.modules.warehouse.dashboard.ui.WarehouseSidebar?>

<fx:root type="BorderPane" styleClass="page-shell" xmlns="http://javafx.com/javafx/17"
         xmlns:fx="http://javafx.com/fxml/1">
    <stylesheets>
        <URL value="@InboundOrderListPage.css"/>
    </stylesheets>
    <left>
        <WarehouseSidebar fx:id="sidebar"/>
    </left>
    <top>
        <WarehouseTopBarUI/>
    </top>
    <center>
        <ScrollPane fitToWidth="true" styleClass="content-scroll">
            <VBox spacing="18.0" styleClass="page-content">
                <padding>
                    <Insets bottom="32.0" left="24.0" right="24.0" top="24.0"/>
                </padding>

                <VBox spacing="5.0">
                    <Label styleClass="page-title" text="Danh sách Đơn Nhập Kho"/>
                    <Label styleClass="page-subtitle" text="Quản lý và xử lý các đơn hàng nhập kho từ nhà cung cấp"/>
                </VBox>

                <HBox alignment="CENTER_LEFT" spacing="14.0" styleClass="filter-panel">
                    <TextField fx:id="keywordField" onAction="#onSearchClick" promptText="Tìm theo mã đơn hàng, mã yêu cầu, hoặc nhà cung cấp..."
                               styleClass="search-input" HBox.hgrow="ALWAYS"/>
                    <ComboBox fx:id="statusFilter" onAction="#onSearchClick" prefWidth="245.0" styleClass="status-filter"/>
                </HBox>

                <HBox alignment="CENTER_LEFT">
                    <Label fx:id="resultCountLabel" styleClass="result-count" text="Hiển thị 0 đơn hàng"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button mnemonicParsing="false" onAction="#onSortClick" styleClass="sort-button" text="⇅  Sắp xếp"/>
                </HBox>

                <VBox styleClass="table-panel">
                    <TableView fx:id="inboundOrderTable" prefHeight="430.0" styleClass="warehouse-table">
                        <columns>
                            <TableColumn fx:id="orderCodeColumn" prefWidth="150.0" text="MÃ ĐƠN HÀNG"/>
                            <TableColumn fx:id="requestCodeColumn" prefWidth="140.0" text="MÃ YÊU CẦU"/>
                            <TableColumn fx:id="supplierColumn" prefWidth="190.0" text="NHÀ CUNG CẤP"/>
                            <TableColumn fx:id="receivedDateColumn" prefWidth="140.0" text="NGÀY NHẬN"/>
                            <TableColumn fx:id="expectedDateColumn" prefWidth="140.0" text="NGÀY DỰ KIẾN"/>
                            <TableColumn fx:id="itemCountColumn" prefWidth="115.0" text="SỐ MẶT HÀNG"/>
                            <TableColumn fx:id="totalQuantityColumn" prefWidth="105.0" text="TỔNG SL"/>
                            <TableColumn fx:id="statusColumn" prefWidth="155.0" text="TRẠNG THÁI"/>
                            <TableColumn fx:id="actionColumn" prefWidth="120.0" text="THAO TÁC"/>
                        </columns>
                    </TableView>
                </VBox>
            </VBox>
        </ScrollPane>
    </center>
</fx:root>
