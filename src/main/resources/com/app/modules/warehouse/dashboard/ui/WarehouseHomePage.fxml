<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import com.app.common.ui.components.WarehouseTopBarUI?>
<?import com.app.modules.warehouse.dashboard.ui.WarehouseSidebar?>

<fx:root type="BorderPane" styleClass="page-shell" xmlns="http://javafx.com/javafx/17"
         xmlns:fx="http://javafx.com/fxml/1">
    <stylesheets>
        <URL value="@WarehouseHomePage.css"/>
    </stylesheets>
    <left>
        <WarehouseSidebar fx:id="sidebar"/>
    </left>
    <top>
        <WarehouseTopBarUI/>
    </top>
    <center>
        <ScrollPane fitToWidth="true" styleClass="content-scroll">
            <VBox spacing="26.0" styleClass="page-content">
                <padding>
                    <Insets bottom="32.0" left="34.0" right="34.0" top="34.0"/>
                </padding>

                <VBox spacing="6.0">
                    <Label styleClass="page-title" text="Trang Chủ - Bộ phận Quản lý Kho"/>
                    <Label styleClass="page-subtitle" text="Tổng quan về hoạt động nhập kho và xử lý hàng hóa"/>
                </VBox>

                <GridPane hgap="24.0" styleClass="metrics-grid">
                    <columnConstraints>
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="25.0"/>
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="25.0"/>
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="25.0"/>
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="25.0"/>
                    </columnConstraints>
                    <VBox styleClass="metric-card" GridPane.columnIndex="0">
                        <HBox alignment="TOP_LEFT">
                            <VBox spacing="8.0">
                                <Label styleClass="metric-title" text="Đơn Chờ Nhập Kho"/>
                                <Label fx:id="pendingInboundLabel" styleClass="metric-value" text="0"/>
                            </VBox>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label fx:id="pendingMetricIcon" styleClass="metric-icon orange"/>
                        </HBox>
                    </VBox>
                    <VBox styleClass="metric-card" GridPane.columnIndex="1">
                        <HBox alignment="TOP_LEFT">
                            <VBox spacing="8.0">
                                <Label styleClass="metric-title" text="Đang Xử Lý"/>
                                <Label fx:id="processingLabel" styleClass="metric-value" text="0"/>
                            </VBox>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label fx:id="processingMetricIcon" styleClass="metric-icon blue"/>
                        </HBox>
                    </VBox>
                    <VBox styleClass="metric-card" GridPane.columnIndex="2">
                        <HBox alignment="TOP_LEFT">
                            <VBox spacing="8.0">
                                <Label styleClass="metric-title" text="Đã Nhập Tháng này"/>
                                <Label fx:id="importedThisMonthLabel" styleClass="metric-value" text="0"/>
                            </VBox>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label fx:id="importedMetricIcon" styleClass="metric-icon green"/>
                        </HBox>
                    </VBox>
                    <VBox styleClass="metric-card" GridPane.columnIndex="3">
                        <HBox alignment="TOP_LEFT">
                            <VBox spacing="8.0">
                                <Label styleClass="metric-title" text="Có Sai Lệch"/>
                                <Label fx:id="mismatchLabel" styleClass="metric-value" text="0"/>
                            </VBox>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label fx:id="mismatchMetricIcon" styleClass="metric-icon red"/>
                        </HBox>
                    </VBox>
                </GridPane>

                <VBox spacing="18.0" styleClass="panel">
                    <Label styleClass="section-title" text="Thao tác Nhanh"/>
                    <HBox spacing="18.0">
                        <HBox alignment="CENTER_LEFT" spacing="14.0" onMouseClicked="#onProcessInboundClick"
                              styleClass="quick-action" HBox.hgrow="ALWAYS">
                            <Label fx:id="quickProcessIcon" styleClass="quick-icon success"/>
                            <VBox spacing="3.0">
                                <Label styleClass="quick-title" text="Xử lý Đơn Nhập Kho"/>
                                <Label styleClass="quick-subtitle" text="Kiểm tra và nhập hàng vào kho"/>
                            </VBox>
                        </HBox>
                        <HBox alignment="CENTER_LEFT" spacing="14.0" onMouseClicked="#onMismatchClick"
                              styleClass="quick-action danger" HBox.hgrow="ALWAYS">
                            <Label fx:id="quickMismatchIcon" styleClass="quick-icon danger"/>
                            <VBox spacing="3.0">
                                <Label styleClass="quick-title" text="Xem Đơn Có Sai Lệch"/>
                                <Label styleClass="quick-subtitle" text="Xử lý các trường hợp thiếu/sai hàng"/>
                            </VBox>
                        </HBox>
                    </HBox>
                </VBox>

                <VBox spacing="18.0" styleClass="panel">
                    <HBox alignment="CENTER_LEFT">
                        <Label styleClass="section-title" text="Đơn Nhập Kho Gần đây"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label onMouseClicked="#onViewAllClick" styleClass="view-all-link" text="Xem tất cả →"/>
                    </HBox>
                    <TableView fx:id="recentOrderTable" prefHeight="285.0" styleClass="warehouse-table">
                        <columns>
                            <TableColumn fx:id="orderCodeColumn" prefWidth="230.0" text="MÃ ĐƠN HÀNG"/>
                            <TableColumn fx:id="receivedDateColumn" prefWidth="190.0" text="NGÀY NHẬN"/>
                            <TableColumn fx:id="supplierColumn" prefWidth="250.0" text="NHÀ CUNG CẤP"/>
                            <TableColumn fx:id="statusColumn" prefWidth="230.0" text="TRẠNG THÁI"/>
                            <TableColumn fx:id="actionColumn" prefWidth="140.0" text="THAO TÁC"/>
                        </columns>
                    </TableView>
                </VBox>
            </VBox>
        </ScrollPane>
    </center>
</fx:root>
