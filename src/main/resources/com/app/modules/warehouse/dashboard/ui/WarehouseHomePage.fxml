<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import com.app.common.ui.components.WarehouseSidebarUI?>
<?import com.app.common.ui.components.WarehouseTopBarUI?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<fx:root type="BorderPane" styleClass="page-shell" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
    <stylesheets>
        <URL value="@WarehouseHomePage.css"/>
        <URL value="/com/app/common/ui/components/WarehouseComponents.css"/>
    </stylesheets>
    <left>
        <WarehouseSidebarUI fx:id="sidebar"/>
    </left>
    <top>
        <WarehouseTopBarUI/>
    </top>
    <center>
        <VBox spacing="26.0" styleClass="page-content">
            <padding>
                <Insets bottom="28.0" left="34.0" right="34.0" top="10.0"/>
            </padding>
            <GridPane hgap="26.0" styleClass="summary-grid">
                <VBox styleClass="summary-card" GridPane.columnIndex="0">
                    <Label styleClass="summary-title" text="Đơn Chờ Nhập Kho"/>
                    <HBox alignment="CENTER_LEFT">
                        <Label fx:id="pendingInboundLabel" styleClass="summary-value" text="12"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label styleClass="summary-icon orange" text="◷"/>
                    </HBox>
                </VBox>
                <VBox styleClass="summary-card" GridPane.columnIndex="1">
                    <Label styleClass="summary-title" text="Đang Xử Lý"/>
                    <HBox alignment="CENTER_LEFT">
                        <Label fx:id="processingLabel" styleClass="summary-value" text="5"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label styleClass="summary-icon blue" text="▣"/>
                    </HBox>
                </VBox>
                <VBox styleClass="summary-card" GridPane.columnIndex="2">
                    <Label styleClass="summary-title" text="Đã Nhập Tháng này"/>
                    <HBox alignment="CENTER_LEFT">
                        <Label fx:id="importedThisMonthLabel" styleClass="summary-value" text="87"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label styleClass="summary-icon green" text="↗"/>
                    </HBox>
                </VBox>
                <VBox styleClass="summary-card" GridPane.columnIndex="3">
                    <Label styleClass="summary-title" text="Có Sai Lệch"/>
                    <HBox alignment="CENTER_LEFT">
                        <Label fx:id="mismatchLabel" styleClass="summary-value" text="3"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label styleClass="summary-icon red" text="⚠"/>
                    </HBox>
                </VBox>
            </GridPane>

            <VBox spacing="22.0" styleClass="panel">
                <Label styleClass="section-title" text="Thao tác Nhanh"/>
                <HBox spacing="22.0">
                    <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#onProcessInboundClick"
                            styleClass="quick-action" text="▣  Xử lý Đơn Nhập Kho&#10;Kiểm tra và nhập hàng vào kho"
                            HBox.hgrow="ALWAYS"/>
                    <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#onMismatchClick"
                            styleClass="quick-action danger" text="⚠  Xem Đơn Có Sai Lệch&#10;Xử lý các trường hợp thiếu/sai hàng"
                            HBox.hgrow="ALWAYS"/>
                </HBox>
            </VBox>

            <VBox spacing="18.0" styleClass="panel">
                <HBox alignment="CENTER_LEFT">
                    <Label styleClass="section-title" text="Đơn Nhập Kho Gần đây"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button mnemonicParsing="false" onAction="#onViewAllClick" styleClass="link-button" text="Xem tất cả →"/>
                </HBox>
                <TableView fx:id="recentOrderTable" prefHeight="300.0" styleClass="warehouse-table">
                    <columns>
                        <TableColumn fx:id="orderCodeColumn" prefWidth="210.0" text="MÃ ĐƠN HÀNG"/>
                        <TableColumn fx:id="receivedDateColumn" prefWidth="170.0" text="NGÀY NHẬN"/>
                        <TableColumn fx:id="supplierColumn" prefWidth="230.0" text="NHÀ CUNG CẤP"/>
                        <TableColumn fx:id="statusColumn" prefWidth="230.0" text="TRẠNG THÁI"/>
                        <TableColumn fx:id="actionColumn" prefWidth="130.0" text="THAO TÁC"/>
                    </columns>
                </TableView>
            </VBox>
        </VBox>
    </center>
</fx:root>
