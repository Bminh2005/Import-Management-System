<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<fx:root type="ScrollPane" xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fitToWidth="true"
            styleClass="screen-scroll">

    <stylesheets>
        <URL value="@../../../../common/ui/components/components.css"/>
        <URL value="@process-import-request-detail.css"/>
    </stylesheets>

    <VBox styleClass="main-content process-request-detail" spacing="22">
        <padding>
            <Insets top="28" right="32" bottom="28" left="32"/>
        </padding>

        <!-- Header -->
        <HBox alignment="CENTER_LEFT" spacing="14">
            <Button text="← Quay lại"
                    styleClass="back-button"
                    onAction="#onBack"/>

            <VBox spacing="5" HBox.hgrow="ALWAYS">
                <Label fx:id="titleLabel"
                       text="Xử lý yêu cầu cụ thể"
                       styleClass="page-title"/>
                <Label text="Phân bổ từng mặt hàng đến site có tồn kho và xác nhận"
                       styleClass="page-subtitle"/>
            </VBox>

            <Label fx:id="statusBadge"
                   text="Chờ xử lý"
                   styleClass="status-badge status-pending"/>
        </HBox>

        <!-- Request overview -->
        <GridPane hgap="18" vgap="18">
            <columnConstraints>
                <ColumnConstraints percentWidth="33.33"/>
                <ColumnConstraints percentWidth="33.33"/>
                <ColumnConstraints percentWidth="33.33"/>
            </columnConstraints>

            <VBox styleClass="card info-card" GridPane.columnIndex="0" spacing="8">
                <Label text="Mã yêu cầu" styleClass="info-title"/>
                <Label fx:id="requestCodeLabel" text="-" styleClass="info-value"/>
            </VBox>

            <VBox styleClass="card info-card" GridPane.columnIndex="1" spacing="8">
                <Label text="Ngày tạo" styleClass="info-title"/>
                <Label fx:id="createdDateLabel" text="-" styleClass="info-value"/>
            </VBox>

            <VBox styleClass="card info-card" GridPane.columnIndex="2" spacing="8">
                <Label text="Người tạo" styleClass="info-title"/>
                <Label fx:id="createdByLabel" text="-" styleClass="info-value"/>
            </VBox>
        </GridPane>

        <!-- Allocation section -->
        <VBox styleClass="card items-card" spacing="14">
            <HBox alignment="CENTER_LEFT" spacing="12">
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <Label text="Phân bổ mặt hàng theo site"
                           styleClass="section-title"/>
                    <Label fx:id="itemCountLabel"
                           text="0 mặt hàng"
                           styleClass="section-subtitle"/>
                </VBox>

                <Button text="Tự động phân bổ"
                        styleClass="outline-button"
                        onAction="#onAuto"/>
            </HBox>

            <Label text="Hệ thống tự đề xuất số lượng theo tồn kho và ngày nhận. Bạn có thể chỉnh tay số lượng ở từng site trước khi xác nhận."
                   wrapText="true"
                   styleClass="section-subtitle"/>

            <VBox fx:id="itemsList" spacing="14"/>
        </VBox>

        <!-- Actions -->
        <HBox spacing="12" alignment="CENTER_LEFT">
            <Label fx:id="messageLabel" text="" wrapText="true" HBox.hgrow="ALWAYS"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Từ chối"
                    styleClass="danger-button"
                    onAction="#onReject"/>
            <Button text="Xác nhận phân bổ"
                    styleClass="primary-button"
                    onAction="#onConfirmAllocation"/>
        </HBox>
    </VBox>
</fx:root>
