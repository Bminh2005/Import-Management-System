<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.SVGPath?>

<?import javafx.collections.FXCollections?>
<?import java.lang.String?>
<fx:root type="StackPane" prefHeight="560.0" prefWidth="820.0" styleClass="root-container" stylesheets="@loginStyle.css"
         xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">

    <children>

        <VBox alignment="CENTER" maxWidth="340.0" spacing="18.0" styleClass="login-card">

            <padding>
                <Insets bottom="24.0" left="24.0" right="24.0" top="24.0"/>
            </padding>

            <children>

                <!-- HEADER -->
                <VBox alignment="CENTER" spacing="10.0">

                    <children>

                        <!-- LOGO -->
                        <StackPane maxHeight="58.0" maxWidth="58.0" minHeight="58.0" minWidth="58.0" prefHeight="58.0"
                                   prefWidth="58.0" styleClass="logo-container">

                            <children>

                                <!-- ORIGINAL SVG -->
                                <SVGPath
                                        content="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"
                                        fill="white" scaleX="1.6" scaleY="1.6"/>

                            </children>

                        </StackPane>

                        <VBox alignment="CENTER" spacing="6.0">

                            <children>

                                <Label styleClass="title-label" text="Đăng nhập hệ thống"/>

                                <Label styleClass="subtitle-label" text="Hệ thống Đặt hàng Nhập khẩu"/>

                            </children>

                        </VBox>

                    </children>

                </VBox>

                <!-- FORM -->
                <VBox spacing="10.0">

                    <children>

                        <!-- EMAIL -->
                        <VBox spacing="8.0">

                            <children>

                                <Label styleClass="field-label" text="Email"/>

                                <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="input-container">

                                    <padding>
                                        <Insets left="10.0" right="10.0"/>
                                    </padding>

                                    <children>

                                        <SVGPath
                                                content="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"
                                                fill="#64748b" scaleX="0.72" scaleY="0.72"/>

                                        <TextField fx:id="email" promptText="email@example.com" HBox.hgrow="ALWAYS"/>

                                    </children>

                                </HBox>

                            </children>

                        </VBox>

                        <!-- PASSWORD -->
                        <VBox spacing="8.0">

                            <children>

                                <Label styleClass="field-label" text="Mật khẩu"/>

                                <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="input-container">

                                    <padding>
                                        <Insets left="14.0" right="14.0"/>
                                    </padding>

                                    <children>

                                        <SVGPath
                                                content="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zm-6 9c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zm3.1-9H8.9V6c0-1.71 1.39-3.1 3.1-3.1 1.71 0 3.1 1.39 3.1 3.1v2z"
                                                fill="#64748b" scaleX="0.72" scaleY="0.72"/>

                                        <PasswordField fx:id="password" promptText="••••••••" HBox.hgrow="ALWAYS"/>

                                    </children>

                                </HBox>

                            </children>

                        </VBox>

                        <!-- ROLE -->
                        <VBox spacing="8.0">

                            <children>

                                <Label styleClass="field-label" text="Vai trò hệ thống"/>

                                <HBox alignment="CENTER_LEFT" spacing="8.0" styleClass="input-container">

                                    <padding>
                                        <Insets left="10.0" right="10.0"/>
                                    </padding>

                                    <children>

                                        <SVGPath
                                                content="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2z"
                                                fill="#64748b" scaleX="0.7" scaleY="0.7"/>

                                        <ComboBox fx:id="roleComboBox" prefHeight="27.0" prefWidth="284.0"
                                                  promptText="Chọn vai trò" HBox.hgrow="ALWAYS">
                                            <items>
                                                <FXCollections fx:factory="observableArrayList">
                                                    <String fx:value="Quản trị viên (Admin)"/>
                                                    <String fx:value="Bộ phận quản lý kho"/>
                                                    <String fx:value="Bộ phận bán hàng"/>
                                                    <String fx:value="Bộ phận đặt hàng quốc tế"/>
                                                </FXCollections>
                                            </items>
                                        </ComboBox>

                                    </children>

                                </HBox>

                            </children>

                        </VBox>
                    </children>

                </VBox>

                <!-- BUTTONS -->
                <VBox spacing="12.0">

                    <children>

                        <Button fx:id="loginButton" maxWidth="Infinity" styleClass="login-button" text="Đăng nhập"/>

                        <Hyperlink fx:id="signupLink" styleClass="register-link"
                                   text="Chưa có tài khoản? Đăng ký ngay"/>

                    </children>

                </VBox>

            </children>

        </VBox>

    </children>

</fx:root>
