<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>

<fx:root type="HBox" xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      alignment="CENTER_LEFT"
      spacing="8"
      styleClass="pagination-bar"
      stylesheets="@pagination-bar.css">
    <Label fx:id="summaryLabel" styleClass="text-xs-secondary" HBox.hgrow="ALWAYS"/>
    <Button fx:id="prevButton" text="Trước" styleClass="btn-page" disable="true"/>
    <Button fx:id="page1Button" text="1" styleClass="btn-page-active"/>
    <Button fx:id="page2Button" text="2" styleClass="btn-page"/>
    <Button fx:id="nextButton" text="Sau" styleClass="btn-page"/>
</fx:root>
