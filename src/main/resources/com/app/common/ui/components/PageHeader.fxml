<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<fx:root type="HBox" xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      alignment="CENTER_LEFT"
      styleClass="page-header"
      stylesheets="@page-header.css">
    <VBox spacing="2" HBox.hgrow="ALWAYS">
        <Label fx:id="titleLabel" styleClass="page-title"/>
        <Label fx:id="subtitleLabel" styleClass="page-subtitle"/>
    </VBox>
    <HBox fx:id="actionContainer">
        <Button fx:id="actionButton" styleClass="btn-primary"/>
    </HBox>
</fx:root>
