<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<fx:root type="javafx.scene.layout.HBox" alignment="CENTER_LEFT" minHeight="72.0"
         spacing="16.0" styleClass="app-topbar"
         xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
    <stylesheets>
        <URL value="@AppTopBar.css"/>
    </stylesheets>
    <padding>
        <Insets bottom="12" left="28" right="28" top="12"/>
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="10" styleClass="global-search-box"
          HBox.hgrow="SOMETIMES">
        <Label styleClass="search-icon" text="🔍"/>
        <TextField fx:id="searchField" promptText="Tìm kiếm đơn hàng, mặt hàng, site..."
                   styleClass="global-search-field" HBox.hgrow="ALWAYS"/>
    </HBox>

    <Region HBox.hgrow="ALWAYS"/>

    <Button mnemonicParsing="false" onAction="#onLanguageClick"
            styleClass="top-ghost-button" text="VI  ⌄"/>

    <Button fx:id="notificationButton" mnemonicParsing="false"
            onAction="#onNotificationClick" styleClass="notification-button" text="🔔"/>

    <HBox alignment="CENTER_LEFT" spacing="10" styleClass="user-chip">
        <Button fx:id="avatarButton" mnemonicParsing="false"
                onAction="#onUserMenuClick" styleClass="avatar-button" text="A"/>
        <VBox spacing="0">
            <Label fx:id="userNameLabel" styleClass="user-name" text="Nguyễn Văn A"/>
            <Label fx:id="roleLabel" styleClass="user-role" text="Bộ phận Bán hàng"/>
        </VBox>
        <Button mnemonicParsing="false" onAction="#onUserMenuClick"
                styleClass="caret-button" text="⌄"/>
    </HBox>
</fx:root>
