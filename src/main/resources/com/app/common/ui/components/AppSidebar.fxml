<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<fx:root type="javafx.scene.layout.VBox" prefWidth="260.0" styleClass="app-sidebar"
         xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
    <stylesheets>
        <URL value="@AppSidebar.css"/>
    </stylesheets>
    <padding>
        <Insets top="20" right="14" bottom="20" left="14"/>
    </padding>

    <!-- Brand -->
    <HBox alignment="CENTER_LEFT" spacing="12" styleClass="brand-box">
        <Label styleClass="brand-icon" text="◎"/>
        <VBox>
            <Label styleClass="brand-title" text="Hệ thống Nhập khẩu"/>
            <Label fx:id="brandSubtitleLabel" styleClass="brand-subtitle"
                   text="Quản lý đa bộ phận"/>
        </VBox>
    </HBox>

    <!-- Menu -->
    <VBox spacing="6" styleClass="sidebar-menu">
        <Label styleClass="sidebar-section-label" text="TỔNG QUAN"/>
        <Button fx:id="homeButton" maxWidth="Infinity" mnemonicParsing="false"
                onAction="#onHomeClick" styleClass="sidebar-button"
                text="⌂   Trang chủ"/>

        <Label styleClass="sidebar-section-label" text="BÁN HÀNG"/>
        <Button fx:id="requestButton" maxWidth="Infinity" mnemonicParsing="false"
                onAction="#onRequestClick" styleClass="sidebar-button"
                text="📝   Yêu cầu Nhập hàng"/>

        <Label styleClass="sidebar-section-label" text="KHO BÃI"/>
        <Button fx:id="inventoryButton" maxWidth="Infinity" mnemonicParsing="false"
                onAction="#onInventoryClick" styleClass="sidebar-button"
                text="📦   Mặt hàng Tồn kho"/>

        <Label styleClass="sidebar-section-label" text="HỆ THỐNG"/>
        <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#onReportsClick"
                styleClass="sidebar-button" text="📊   Báo cáo"/>
        <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#onSettingsClick"
                styleClass="sidebar-button" text="⚙   Cài đặt"/>
    </VBox>

    <Region VBox.vgrow="ALWAYS"/>

    <!-- Role panel -->
    <VBox spacing="8" styleClass="role-panel">
        <Label styleClass="role-muted" text="VAI TRÒ"/>
        <Label fx:id="roleLabel" styleClass="role-title" text="Bộ phận Bán hàng"/>
        <Button maxWidth="Infinity" mnemonicParsing="false"
                onAction="#onSwitchDepartmentClick"
                styleClass="ghost-sidebar-button" text="Đổi bộ phận"/>
    </VBox>

    <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#onCollapseClick"
            styleClass="collapse-button" text="‹   Thu gọn"/>
</fx:root>
