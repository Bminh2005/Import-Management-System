    <!-- Khu vực Footer Sidebar (Vai trò hiện tại) -->
    <VBox style="-fx-padding: 20; -fx-background-color: rgba(0,0,0,0.1);" spacing="10">
        <VBox style="-fx-background-color: #3b66d1; -fx-background-radius: 8; -fx-padding: 10;">
            <Label text="Vai trò hiện tại" style="-fx-text-fill: #94a3b8; -fx-font-size: 11px;"/>
            <Label fx:id="currentRole" text="Bộ phận Bán hàng" style="-fx-text-fill: white; -fx-font-weight: bold;"/>
        </VBox>
        <Button fx:id="logoutButton" text="Đăng xuất"
                style="-fx-background-color: transparent; -fx-border-color: #475569; -fx-border-radius: 4; -fx-text-fill: #94a3b8;"
                maxWidth="Infinity"/>
        <HBox fx:id="toggleButton" alignment="CENTER" style="-fx-padding: 10 0 0 0;">
            <Label fx:id="toggleLabel" text="&lt; Thu Gọn" style="-fx-text-fill: #94a3b8; -fx-cursor: hand;"/>
        </HBox>
    </VBox>
