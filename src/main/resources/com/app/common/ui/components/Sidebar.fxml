<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<fx:root type="VBox" stylesheets="@SidebarStyle.css" styleClass="sidebar" prefWidth="250.0" spacing="10"
         xmlns="http://javafx.com/javafx/17"
         xmlns:fx="http://javafx.com/fxml/1"
>

    <!-- Logo & Tên hệ thống -->
    <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding: 20;">
        <Label text="🌐" style="-fx-font-size: 24px; -fx-text-fill: white;"/>
        <VBox alignment="CENTER_LEFT">
            <Label fx:id="systemName" text="Hệ thống Nhập hàng" styleClass="sidebar-logo-text"/>
            <Label fx:id="departmentName" text="Bộ phận Bán hàng" style="-fx-text-fill: #cbd5e1; -fx-font-size: 12px;"/>
        </VBox>
    </HBox>

