<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>

<fx:root alignment="CENTER_LEFT" styleClass="nav-item" type="HBox" xmlns="http://javafx.com/javafx/17"
         xmlns:fx="http://javafx.com/fxml/1">
    <Label fx:id="iconLabel" text="" style="-fx-text-fill: white; -fx-padding: 0 10 0 0;"/>

    <Label fx:id="textLabel" maxWidth="Infinity" styleClass="nav-text" text="Trang Chủ Bán Hàng" HBox.hgrow="ALWAYS"/>

    <Label fx:id="shortCutLabel" styleClass="nav-shortcut" text="Ctrl+1"/>

</fx:root>
